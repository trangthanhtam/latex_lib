% --- Trục Oxy ---
\newcommand{\Oxy}[4]{
	% --- Vẽ trục toạ độ có 4 toạ độ cho trước --- %
    \draw[->] (#1,0) -- (#2,0) node[below] {\footnotesize $x$};
    \draw[->] (0,#3) -- (0,#4) node[right] {\footnotesize $y$};
    
    % --- Viết số 0 tại gốc toạ độ, ở dưới bên trái và đẩy lên 3pt để gần với gốc hơn --- %
    \node at (0,0) [below left, xshift=3pt, yshift=3pt] {\footnotesize O};
    \fill (0,0) circle (1.5pt);
	
	% --- Khi vẽ thì sẽ vẽ dư ra 1 đơn vị --- %
    \pgfmathtruncatemacro{\xstart}{#1+1}
    \pgfmathtruncatemacro{\xend}{#2-1}
    \pgfmathtruncatemacro{\ystart}{#3+1}
    \pgfmathtruncatemacro{\yend}{#4-1}

	% --- Vẽ các điểm trên trục x và y --- %
    \foreach \x in {\xstart,...,\xend} {
        \ifnum \x=0 \else
            \draw (\x,0.1) -- (\x,-0.1) node[below] {\footnotesize \x};
        \fi
    }

    \foreach \y in {\ystart,...,\yend} {
        \ifnum \y=0 \else
            \draw (0.1,\y) -- (-0.1,\y) node[left] {\footnotesize \y};
        \fi
    }
}

