% --- tạo biến lưu biến độ dài của từng đáp án --- %
\newlength{\widthA}
\newlength{\widthB}
\newlength{\widthC}
\newlength{\widthD}

% --- tạo biến lưu độ dài của câu dài nhất --- %
\newlength{\maxWidth}

% --- tạo biến số lượng cột để xem chia thành 1, 2 hay 4 cột --- %
\newcounter{numCols}

% --- Câu trắc nghiệm trong khu vực Trắc nghiệm --- %
\newcommand{\CauTracNghiem}[5]{
    % --- nội dung câu hỏi --- %
    \item #1
    
    % --- phần đáp án --- %
    
    % --- lấy độ dài của câu hỏi --- %
    \settowidth{\widthA}{\printclean{#2}}
    \settowidth{\widthB}{\printclean{#3}}
    \settowidth{\widthC}{\printclean{#4}}
    \settowidth{\widthD}{\printclean{#5}}
    
    % --- xem câu trả lời nào dài nhất --- %
    \setlength{\maxWidth}{\widthA}
    \ifdim\widthB>\maxWidth \setlength{\maxWidth}{\widthB} \fi
    \ifdim\widthC>\maxWidth \setlength{\maxWidth}{\widthC} \fi
    \ifdim\widthD>\maxWidth \setlength{\maxWidth}{\widthD} \fi
    
    % --- kiểm tra độ rộng để quyết định là 1 2 hay 4 cột --- %
    \setcounter{numCols}{4}
    \ifdim\maxWidth>0.45\textwidth \setcounter{numCols}{1}
    \else
    	\ifdim\maxWidth>0.22\textwidth \setcounter{numCols}{2}
    	\else
    		\setcounter{numCols}{4}
    	\fi
    \fi
    \miniCauTracNghiem{\value{numCols}}{#2}{#3}{#4}{#5}
}

% --- hàm gắn giá trị vào ---%
\newcommand{\miniCauTracNghiem}[5]{
	\begin{itemize}[
		leftmargin=50pt, 
		label={},
		noitemsep,
		] 
	\item
	\begin{tasks}[
		label=\textbf{\Alph*.},
		label-width=15pt,
		item-indent=20pt,
		column-sep=10pt,
		after-item-skip=5pt,
		before-skip=0pt,
		](#1)
		\task \checkDung{#2}{\textcolor{red}{\textbf{\printclean{#2}}}}{\printclean{#2}}
        \task \checkDung{#3}{\textcolor{red}{\textbf{\printclean{#3}}}}{\printclean{#3}}
        \task \checkDung{#4}{\textcolor{red}{\textbf{\printclean{#4}}}}{\printclean{#4}}
        \task \checkDung{#5}{\textcolor{red}{\textbf{\printclean{#5}}}}{\printclean{#5}}
	\end{tasks}
\end{itemize}
}
