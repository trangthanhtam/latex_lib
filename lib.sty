\makeatletter
\def\Dung{DUNG}
\def\Sai{SAI}
% --- Hàm kiểm tra xem có chữ \dung \saii trong câu trả lời không --- %
\newcommand{\IfContains}[4]{%
	\protected@edef\temp@content{#1}%
    \def\check##1#2##2##3\@nil{\ifx\relax##2\relax#4\else#3\fi}%
    \expandafter\check\temp@content#2\relax\relax\@nil%
}

\def\remove@DUNG#1DUNG#2\@nil{#1#2}
\def\remove@SAI#1SAI#2\@nil{#1#2}

\newcommand{\printclean}[1]{%
	\protected@edef\temp@clean{#1}%
    \IfContains{\temp@clean}{DUNG}{%
        \expandafter\remove@DUNG\temp@clean\@nil%
    }{%
        \IfContains{\temp@clean}{SAI}{%
            \expandafter\remove@SAI\temp@clean\@nil%
        }{#1}%
    }%
}

% --- Hàm tạo chữ X cho đáp án đúng sai --- %
\newcommand{\checkDung}[3]{%
	\ifbool{isTeacher}{
		\IfContains{#1}{DUNG}{#2}{#3}%
		}{#3}%
}

\newcommand{\checkSai}[3]{%
	\ifbool{isTeacher}{%
		\IfContains{#1}{SAI}{#2}{#3}%
		}{#3}%
}
\makeatother
